# Copy to .env and fill in. Never commit your real .env.

NODE_ENV=development

# The SAME database the scrobbler (Phase 1) writes to. Phase 2 reads `plays`
# and writes its own canonical tables alongside.
DATABASE_URL=postgres://scrobbler:scrobbler@localhost:5432/scrobbler

# How many unresolved plays to process per batch (optional; default shown).
MATCH_BATCH_SIZE=500
